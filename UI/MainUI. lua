function DyX:Toggle()
	self.Visible = not self.Visible
	self.Root.Visible = self.Visible
end

function DyX:SetTheme(name)
	if not DyX.Themes[name] then return end

	self.Settings.Theme = name
	self:SaveConfig()

	if self.ReloadOnThemeChange then
		self:Reload()
	else
		self.Theme = DyX.Themes[name]
	end
end

function DyX:SetOpacity(value)
	self.Settings.BackgroundOpacity = value
	self.Root.BackgroundTransparency = value
	self:SaveConfig()
end

function DyX:ApplySidebarMode()
	for _, tab in ipairs(self.Tabs) do
		if self.Settings.SidebarMode == "Icon" then
			tab.Button.Text = tab.Icon
			self.Sidebar.Size = UDim2.new(0, 70, 1, -60)
			self.Content.Position = UDim2.new(0, 90, 0, 54)
			self.Content.Size = UDim2.new(1, -98, 1, -60)
		elseif self.Settings.SidebarMode == "Text" then
			tab.Button.Text = tab.Name
			self.Sidebar.Size = UDim2.new(0, 150, 1, -60)
			self.Content.Position = UDim2.new(0, 170, 0, 54)
			self.Content.Size = UDim2.new(1, -178, 1, -60)
		else
			tab.Button.Text = tab.Icon .. "  " .. tab.Name
			self.Sidebar.Size = UDim2.new(0, 160, 1, -60)
			self.Content.Position = UDim2.new(0, 180, 0, 54)
			self.Content.Size = UDim2.new(1, -188, 1, -60)
		end
	end
end

function DyX:CreateTab(name, icon)
	icon = icon or "•"

	local tab = {UI = self, Name = name, Icon = icon}

	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, 0, 0, 38)
	btn.BackgroundColor3 = self.Theme.Element
	btn.TextColor3 = self.Theme.Text
	btn.TextSize = 13
	btn.Font = Enum.Font.GothamBold
	btn.Text = icon .. "  " .. name
	btn.Parent = self.Sidebar
	corner(btn, 10)

	local page = Instance.new("ScrollingFrame")
	page.Size = UDim2.new(1, 0, 1, 0)
	page.BackgroundTransparency = 1
	page.ScrollBarThickness = 4
	page.Visible = false
	page.CanvasSize = UDim2.new(0,0,0,0)
	page.Parent = self.Content

	local layout = Instance.new("UIListLayout")
	layout.Padding = UDim.new(0, 10)
	layout.Parent = page

	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		page.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 24)
	end)

	local pad = Instance.new("UIPadding")
	pad.PaddingTop = UDim.new(0, 12)
	pad.PaddingLeft = UDim.new(0, 12)
	pad.PaddingRight = UDim.new(0, 12)
	pad.PaddingBottom = UDim.new(0, 12)
	pad.Parent = page

	function tab:Show()
		for _, t in ipairs(self.UI.Tabs) do
			t.Page.Visible = false
			t.Button.BackgroundColor3 = self.UI.Theme.Element
		end

		page.Visible = true
		btn.BackgroundColor3 = self.UI.Theme.Accent
	end

	function tab:Section(text)
		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1, 0, 0, 26)
		label.BackgroundTransparency = 1
		label.Text = text
		label.TextColor3 = self.UI.Theme.Muted
		label.TextSize = 13
		label.Font = Enum.Font.GothamBold
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.Parent = page
	end

	function tab:Button(text, callback)
		local b = Instance.new("TextButton")
		b.Size = UDim2.new(1, 0, 0, 42)
		b.BackgroundColor3 = self.UI.Theme.Element
		b.Text = text
		b.TextColor3 = self.UI.Theme.Text
		b.TextSize = 14
		b.Font = Enum.Font.GothamBold
		b.Parent = page
		corner(b, 11)
		stroke(b, self.UI.Theme.Stroke)

		b.MouseEnter:Connect(function()
			tween(b, {BackgroundColor3 = self.UI.Theme.Accent}, 0.15)
		end)

		b.MouseLeave:Connect(function()
			tween(b, {BackgroundColor3 = self.UI.Theme.Element}, 0.15)
		end)

		b.MouseButton1Click:Connect(function()
			if callback then callback() end
		end)

		return b
	end

	function tab:Toggle(text, default, callback)
		local state = default or false

		local b = self:Button(text .. "  [" .. (state and "ON" or "OFF") .. "]", function()
			state = not state
			b.Text = text .. "  [" .. (state and "ON" or "OFF") .. "]"
			if callback then callback(state) end
		end)

		return b
	end

	function tab:Slider(text, min, max, default, callback)
		local value = default or min

		local b = self:Button(text .. ": " .. value, function()
			value += 1
			if value > max then value = min end
			b.Text = text .. ": " .. value
			if callback then callback(value) end
		end)

		return b
	end

	function tab:Dropdown(text, options, default, callback)
		local index = 1

		for i, v in ipairs(options) do
			if v == default then index = i end
		end

		local b = self:Button(text .. ": " .. tostring(options[index]), function()
			index += 1
			if index > #options then index = 1 end

			local selected = options[index]
			b.Text = text .. ": " .. tostring(selected)

			if callback then callback(selected) end
		end)

		return b
	end

	function tab:Textbox(text, placeholder, callback)
		local box = Instance.new("TextBox")
		box.Size = UDim2.new(1, 0, 0, 42)
		box.BackgroundColor3 = self.UI.Theme.Element
		box.Text = ""
		box.PlaceholderText = placeholder or text
		box.TextColor3 = self.UI.Theme.Text
		box.PlaceholderColor3 = self.UI.Theme.Muted
		box.TextSize = 14
		box.Font = Enum.Font.Gotham
		box.Parent = page
		corner(box, 11)
		stroke(box, self.UI.Theme.Stroke)

		box.FocusLost:Connect(function()
			if callback then callback(box.Text) end
		end)

		return box
	end

	btn.MouseButton1Click:Connect(function()
		tab:Show()
	end)

	tab.Button = btn
	tab.Page = page

	table.insert(self.Tabs, tab)

	if #self.Tabs == 1 then
		tab:Show()
	end

	self:ApplySidebarMode()

	return tab
end

function DyX:CreateConfigTab()
	local Config = self:CreateTab("Config", "⚙")

	Config:Section("Interface")

	Config:Dropdown("Tema", (function()
		local list = {}
		for name in pairs(DyX.Themes) do table.insert(list, name) end
		table.sort(list)
		return list
	end)(), self.Settings.Theme, function(value)
		self:SetTheme(value)
	end)

	Config:Dropdown("Sidebar", {"IconText", "Icon", "Text"}, self.Settings.SidebarMode, function(value)
		self.Settings.SidebarMode = value
		self:ApplySidebarMode()
		self:SaveConfig()
	end)

	Config:Slider("Opacidade Fundo", 0, 90, math.floor(self.Settings.BackgroundOpacity * 100), function(value)
		self:SetOpacity(value / 100)
	end)

	Config:Slider("Timer Notify", 1, 15, self.Settings.NotifyTime, function(value)
		self.Settings.NotifyTime = value
		self:SaveConfig()
	end)

	Config:Section("Sistema")

	Config:Toggle("AutoSave", self.Settings.AutoSave, function(value)
		self.Settings.AutoSave = value
		self:SaveConfig()
	end)

	Config:Toggle("AutoExecute", self.Settings.AutoExecute, function(value)
		self.Settings.AutoExecute = value
		self:SaveConfig()
		self:Notify("AutoExecute: " .. tostring(value))
	end)

	Config:Button("Recarregar Interface", function()
		self:Reload()
	end)

	Config:Button("Fechar UI", function()
		self:Toggle()
	end)

	Config:Button("Destruir UI", function()
		self:Destroy()
	end)
end

function DyX:Notify(text, duration)
	duration = duration or self.Settings.NotifyTime or 5

	local n = Instance.new("Frame")
	n.Size = UDim2.new(0, 320, 0, 58)
	n.Position = UDim2.new(1, -340, 1, -80)
	n.BackgroundColor3 = self.Theme.Panel
	n.Parent = self.Gui
	corner(n, 12)
	stroke(n, self.Theme.Stroke)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -52, 1, -8)
	label.Position = UDim2.new(0, 12, 0, 4)
	label.BackgroundTransparency = 1
	label.Text = text
	label.TextColor3 = self.Theme.Text
	label.TextSize = 13
	label.Font = Enum.Font.GothamBold
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextWrapped = true
	label.Parent = n

	local x = Instance.new("TextButton")
	x.Size = UDim2.new(0, 28, 0, 28)
	x.Position = UDim2.new(1, -36, 0, 8)
	x.BackgroundColor3 = self.Theme.Element
	x.Text = "×"
	x.TextColor3 = self.Theme.Text
	x.TextSize = 18
	x.Font = Enum.Font.GothamBold
	x.Parent = n
	corner(x, 8)

	local bar = Instance.new("Frame")
	bar.Size = UDim2.new(1, 0, 0, 3)
	bar.Position = UDim2.new(0, 0, 1, -3)
	bar.BackgroundColor3 = self.Theme.Accent
	bar.Parent = n

	local closed = false

	local function close()
		if closed then return end
		closed = true
		tween(n, {Position = UDim2.new(1, 20, 1, -80)}, 0.2)
		task.delay(0.22, function()
			if n then n:Destroy() end
		end)
	end

	x.MouseButton1Click:Connect(close)

	tween(bar, {Size = UDim2.new(0, 0, 0, 3)}, duration)

	task.delay(duration, close)
end

function DyX:Destroy()
	if self.Gui then
		self.Gui:Destroy()
	end
end

return DyX
