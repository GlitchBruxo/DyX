	self.Sidebar.Position = UDim2.new(0, 10, 0, 50)
	self.Sidebar.BackgroundColor3 = self.Theme.Panel
	self.Sidebar.Parent = self.Root
	corner(self.Sidebar, 12)

	local sidebarList = Instance.new("UIListLayout")
	sidebarList.Padding = UDim.new(0, 8)
	sidebarList.SortOrder = Enum.SortOrder.LayoutOrder
	sidebarList.Parent = self.Sidebar

	local sidebarPad = Instance.new("UIPadding")
	sidebarPad.PaddingTop = UDim.new(0, 10)
	sidebarPad.PaddingLeft = UDim.new(0, 8)
	sidebarPad.PaddingRight = UDim.new(0, 8)
	sidebarPad.Parent = self.Sidebar

	self.Content = Instance.new("Frame")
	self.Content.Size = UDim2.new(1, -170, 1, -54)
	self.Content.Position = UDim2.new(0, 160, 0, 50)
	self.Content.BackgroundColor3 = self.Theme.Panel
	self.Content.Parent = self.Root
	corner(self.Content, 12)

	self.Tabs = {}
	self.CurrentTab = nil

	makeDraggable(self.Root, self.Topbar)

	self.CloseButton.MouseButton1Click:Connect(function()
		self:Toggle()
	end)

	UserInputService.InputBegan:Connect(function(input, gp)
		if gp then return end
		if input.KeyCode == self.ToggleKey then
			self:Toggle()
		end
	end)

	if self.IsMobile then
		self:CreateMobileButton()
	end

	return self
end

function PrivateUI:CreateMobileButton()
	self.Float = Instance.new("TextButton")
	self.Float.Size = UDim2.new(0, 54, 0, 54)
	self.Float.Position = UDim2.new(1, -70, 0.5, -27)
	self.Float.BackgroundColor3 = self.Theme.Accent
	self.Float.Text = "≡"
	self.Float.TextColor3 = Color3.fromRGB(255, 255, 255)
	self.Float.TextSize = 28
	self.Float.Font = Enum.Font.GothamBold
	self.Float.Parent = self.Gui
	corner(self.Float, 100)

	makeDraggable(self.Float, self.Float)

	self.Float.MouseButton1Click:Connect(function()
		self:Toggle()
	end)
end

function PrivateUI:Toggle()
	self.Visible = not self.Visible
	self.Root.Visible = self.Visible
end

function PrivateUI:SetVisible(value)
	self.Visible = value
	self.Root.Visible = value
end

function PrivateUI:CreateTab(name)
	local tab = {}
	tab.UI = self
	tab.Name = name

	local button = Instance.new("TextButton")
	button.Size = UDim2.new(1, 0, 0, 36)
	button.BackgroundColor3 = self.Theme.Element
	button.Text = name
	button.TextColor3 = self.Theme.Text
	button.TextSize = 14
	button.Font = Enum.Font.GothamMedium
	button.Parent = self.Sidebar
	corner(button, 9)

	local page = Instance.new("ScrollingFrame")
	page.Size = UDim2.new(1, 0, 1, 0)
	page.BackgroundTransparency = 1
	page.ScrollBarThickness = 4
	page.Visible = false
	page.Parent = self.Content

	local layout = Instance.new("UIListLayout")
	layout.Padding = UDim.new(0, 10)
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Parent = page

	local pad = Instance.new("UIPadding")
	pad.PaddingTop = UDim.new(0, 12)
	pad.PaddingLeft = UDim.new(0, 12)
	pad.PaddingRight = UDim.new(0, 12)
	pad.PaddingBottom = UDim.new(0, 12)
	pad.Parent = page

	function tab:Show()
		for _, t in pairs(self.UI.Tabs) do
			t.Page.Visible = false
			t.Button.BackgroundColor3 = self.UI.Theme.Element
		end

		page.Visible = true
		button.BackgroundColor3 = self.UI.Theme.Accent
		self.UI.CurrentTab = tab
	end

	function tab:CreateSection(title)
		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1, 0, 0, 28)
		label.BackgroundTransparency = 1
		label.Text = title
		label.TextColor3 = self.UI.Theme.MutedText
		label.TextSize = 13
		label.Font = Enum.Font.GothamBold
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.Parent = page
		return label
	end

	function tab:CreateButton(text, callback)
		local btn = Instance.new("TextButton")
		btn.Size = UDim2.new(1, 0, 0, 40)
		btn.BackgroundColor3 = self.UI.Theme.Element
		btn.Text = text
		btn.TextColor3 = self.UI.Theme.Text
		btn.TextSize = 14
		btn.Font = Enum.Font.Gotham
		btn.Parent = page
		corner(btn, 9)
		stroke(btn, self.UI.Theme.Stroke)

		btn.MouseButton1Click:Connect(function()
			if callback then callback() end
		end)

		return btn
	end

	function tab:CreateToggle(text, default, callback)
		local state = default or false

		local btn = self:CreateButton(text .. ": " .. tostring(state), function()
			state = not state
			btn.Text = text .. ": " .. tostring(state)

			if state then
				btn.BackgroundColor3 = self.UI.Theme.Accent
			else
				btn.BackgroundColor3 = self.UI.Theme.Element
			end

			if callback then callback(state) end
		end)

		return btn
	end

	function tab:CreateSlider(text, min, max, default, callback)
		local value = default or min

		local btn = self:CreateButton(text .. ": " .. tostring(value), function()
			value += 1
			if value > max then
				value = min
			end

			btn.Text = text .. ": " .. tostring(value)

			if callback then callback(value) end
		end)

		return btn
	end

	function tab:CreateTextBox(text, placeholder, callback)
		local box = Instance.new("TextBox")
		box.Size = UDim2.new(1, 0, 0, 40)
		box.BackgroundColor3 = self.UI.Theme.Element
		box.PlaceholderText = placeholder or text
		box.Text = ""
		box.TextColor3 = self.UI.Theme.Text
		box.PlaceholderColor3 = self.UI.Theme.MutedText
		box.TextSize = 14
		box.Font = Enum.Font.Gotham
		box.Parent = page
		corner(box, 9)
		stroke(box, self.UI.Theme.Stroke)

		box.FocusLost:Connect(function()
			if callback then callback(box.Text) end
		end)

		return box
	end

	button.MouseButton1Click:Connect(function()
		tab:Show()
	end)

	tab.Button = button
	tab.Page = page

	table.insert(self.Tabs, tab)

	if not self.CurrentTab then
		tab:Show()
	end

	return tab
end

function PrivateUI:SetTheme(themeName)
	local theme = PrivateUI.Themes[themeName]
	if not theme then return end

	self.ThemeName = themeName
	self.Theme = theme

	self.Root.BackgroundColor3 = theme.Background
	self.Topbar.BackgroundColor3 = theme.Panel
	self.Sidebar.BackgroundColor3 = theme.Panel
	self.Content.BackgroundColor3 = theme.Panel
	self.TitleLabel.TextColor3 = theme.Text
	self.CloseButton.BackgroundColor3 = theme.Element
	self.CloseButton.TextColor3 = theme.Text

	if self.Float then
		self.Float.BackgroundColor3 = theme.Accent
	end
end

function PrivateUI:Notify(text)
	local note = Instance.new("TextLabel")
	note.Size = UDim2.new(0, 280, 0, 42)
	note.Position = UDim2.new(1, -300, 1, -70)
	note.BackgroundColor3 = self.Theme.Panel
	note.Text = text
	note.TextColor3 = self.Theme.Text
	note.TextSize = 14
	note.Font = Enum.Font.Gotham
	note.Parent = self.Gui
	corner(note, 10)
	stroke(note, self.Theme.Stroke)

	task.delay(2.5, function()
		if note then
			note:Destroy()
		end
	end)
end

function PrivateUI:Destroy()
	if self.Gui then
		self.Gui:Destroy()
	end
end

return PrivateUI
