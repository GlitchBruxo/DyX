local function corner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 10)
	c.Parent = parent
	return c
end

local function stroke(parent, color)
	local s = Instance.new("UIStroke")
	s.Color = color
	s.Thickness = 1
	s.Transparency = 0.25
	s.Parent = parent
	return s
end

local function tween(obj, props, time)
	TweenService:Create(
		obj,
		TweenInfo.new(time or 0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		props
	):Play()
end

local function makeDraggable(frame, handle)
	local dragging = false
	local dragStart
	local startPos

	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end)
end

function PrivateUI.new(config)
	config = config or {}

	local self = setmetatable({}, { __index = PrivateUI })

	self.Title = config.Title or "PrivateUI"
	self.ThemeName = config.Theme or "AmoledGreen"
	self.Theme = PrivateUI.Themes[self.ThemeName] or PrivateUI.Themes.AmoledGreen
	self.ToggleKey = config.ToggleKey or Enum.KeyCode.RightShift
	self.Visible = true
	self.IsMobile = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled

	if config.Colors then
		for key, value in pairs(config.Colors) do
			self.Theme[key] = value
		end
	end

	self.Gui = Instance.new("ScreenGui")
	self.Gui.Name = "PrivateUI"
	self.Gui.ResetOnSpawn = false
	self.Gui.IgnoreGuiInset = true
	self.Gui.Parent = Player:WaitForChild("PlayerGui")

	self.Root = Instance.new("Frame")
	self.Root.Size = UDim2.new(0, 580, 0, 370)
	self.Root.Position = UDim2.new(0.5, -290, 0.5, -185)
	self.Root.BackgroundColor3 = self.Theme.Background
	self.Root.BackgroundTransparency = 0.02
	self.Root.Parent = self.Gui
	corner(self.Root, 14)
	stroke(self.Root, self.Theme.Stroke)

	self.Topbar = Instance.new("Frame")
	self.Topbar.Size = UDim2.new(1, 0, 0, 44)
	self.Topbar.BackgroundColor3 = self.Theme.Panel
	self.Topbar.Parent = self.Root
	corner(self.Topbar, 14)

	self.TitleLabel = Instance.new("TextLabel")
