function DyX:SaveConfig()
	if not self.Settings.AutoSave then return end
	if canFile() then
		writefile(self.ConfigFile, HttpService:JSONEncode(self.Settings))
	end
end

function DyX:LoadConfig()
	if canFile() and isfile(self.ConfigFile) then
		local ok, data = pcall(function()
			return HttpService:JSONDecode(readfile(self.ConfigFile))
		end)
		if ok and type(data) == "table" then
			for k, v in pairs(data) do
				self.Settings[k] = v
			end
		end
	end
end

function DyX:Reload()
	self:Notify("Recarregando interface...", 1.5)

	task.delay(0.4, function()
		self:Destroy()

		if self.ReloadCallback then
			self.ReloadCallback()
		elseif self.ScriptUrl and typeof(loadstring) == "function" and game.HttpGet then
			loadstring(game:HttpGet(self.ScriptUrl))()
		end
	end)
end

